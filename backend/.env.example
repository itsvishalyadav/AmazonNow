# Amazon Now — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# AgentRouter (OpenAI-compatible LLM gateway)
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
AGENTROUTER_API_KEY=<your-agentrouter-key>
AGENTROUTER_MODEL=<vision-capable-chat-model-id>
AGENTROUTER_EMBED_MODEL=<embedding-model-id>

# AWS
AWS_REGION=ap-south-1

# Server
PORT=4000
